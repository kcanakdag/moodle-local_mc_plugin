<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/mc_plugin/db" VERSION="20260221" COMMENT="XMLDB file for local_mc_plugin"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_mc_plugin_executions" COMMENT="Tracks executed local actions for idempotency">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="action_type" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="event_fingerprint" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="target_id" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="user_id" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="result" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="executed_at" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_action_fingerprint" UNIQUE="true" FIELDS="action_type, event_fingerprint"/>
        <INDEX NAME="idx_executed_at" UNIQUE="false" FIELDS="executed_at"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
