{{!
    @template local_mc_plugin/action_buttons

    Action buttons component for MoodleConnect admin settings.
    JS routes via core/ajax methodnames; no URL or sesskey data attributes needed.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * data-region="action-buttons" - Main container
    * data-region="action-result" - Result message container
    * data-action="save-sync" - Save and sync button
    * data-region="button-text" - Button text span
    * data-region="button-spinner" - Loading spinner container

    Context variables required for this template:
    * (none)

    Example context (json):
    {}
}}
<div class="local_mc_plugin_action_buttons text-center"
     data-region="action-buttons">
    {{! Result message container - hidden by default }}
    <div data-region="action-result" class="mb-3"></div>

    {{! Save and Sync button - centered }}
    <button type="button"
            class="btn btn-primary btn-lg"
            data-action="save-sync">
        <span data-region="button-text">
            {{#str}} btn_save_sync, local_mc_plugin {{/str}}
        </span>
        <span data-region="button-spinner" class="d-none ml-2">
            {{> core/loading }}
        </span>
    </button>
</div>
