{{!
    @template local_mc_plugin/bulk_sync

    Bulk user sync component for MoodleConnect admin settings.

    This template uses no context variables. All dynamic behavior
    is handled by the bulk_sync AMD module via data-* selectors.

    Data attributes required for JS:
    * data-region="bulk-sync" - Main container
    * data-region="bulk-sync-status" - Status message area
    * data-action="bulk-sync-start" - Sync button
    * data-region="bulk-sync-spinner" - Button spinner
    * data-action="bulk-sync-cancel" - Cancel button
    * data-region="bulk-sync-progress" - Progress container
    * data-region="bulk-sync-bar" - Progress bar
    * data-region="bulk-sync-progress-text" - Progress text
    * data-region="bulk-sync-result" - Result message area

    Example context (json):
    {}
}}
<div data-region="bulk-sync">
    <p class="text-muted small">{{#str}} bulk_sync_desc, local_mc_plugin {{/str}}</p>

    {{! Status area (populated by JS). }}
    <div data-region="bulk-sync-status" class="mb-2 small"></div>

    {{! Button - disabled until preflight confirms trigger exists. }}
    <button type="button" data-action="bulk-sync-start" class="btn btn-outline-secondary" disabled>
        <span data-region="bulk-sync-spinner" class="spinner-border spinner-border-sm d-none mr-1"
              role="status" aria-hidden="true"></span>
        <span>{{#str}} bulk_sync_button, local_mc_plugin {{/str}}</span>
    </button>

    {{! Cancel button (hidden until sync starts). }}
    <button type="button" data-action="bulk-sync-cancel" class="btn btn-outline-danger btn-sm d-none ml-2">
        {{#str}} bulk_sync_cancel, local_mc_plugin {{/str}}
    </button>

    {{! Progress bar (hidden initially). }}
    <div data-region="bulk-sync-progress" class="mt-2 d-none" style="max-width: 400px;">
        <div class="progress" style="height: 20px;">
            <div data-region="bulk-sync-bar" class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
        </div>
        <div data-region="bulk-sync-progress-text" class="small text-muted mt-1"></div>
    </div>

    {{! Result area. }}
    <div data-region="bulk-sync-result" class="mt-2"></div>
</div>
